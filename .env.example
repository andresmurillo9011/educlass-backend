# ======================================================
#  EduClass v5 — Variables de entorno
#  Copia este archivo como .env y llena los valores
#  NUNCA subas .env a GitHub
# ======================================================

# Base de datos PostgreSQL
# En Railway: copia el DATABASE_URL del panel de tu DB
DATABASE_URL="postgresql://usuario:password@host:5432/educlass?schema=public"

# JWT — pon una cadena aleatoria larga y segura
JWT_SECRET="educlass_jwt_super_secreto_2024_cambiame"

# APIs de IA (pon las que tengas, el sistema usa las disponibles)
GROQ_KEY="gsk_..."
TOGETHER_KEY="key_..."
OPENROUTER_KEY="sk-or-v1-..."
GEMINI_KEY="AIza..."

# Puerto (Railway lo asigna automáticamente)
PORT=5000
